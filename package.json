{
  "name": "@fupete/design-system-italia-mcp",
  "version": "0.3.10",
  "description": "Filo – MCP server non ufficiale per il Design system .italia",
  "type": "module",
  "main": "dist/index.js",
  "homepage": "https://github.com/Fupete/design-system-italia-mcp#readme",
  "bugs": {
    "url": "https://github.com/Fupete/design-system-italia-mcp/issues"
  },
  "keywords": [
    "mcp",
    "design-system",
    "design-tokens-italia",
    "bootstrap-italia",
    "dev-kit-italia",
    "italia"
  ],
  "bin": {
    "design-system-italia-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "publiccode.yml"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "canary": "npx tsx scripts/canary.ts",
    "docs-vendor": "node docs/scripts/vendor.mjs",
    "docs-setup": "npm install && npm run docs-vendor"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Fupete/design-system-italia-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "js-yaml": "^4.1.0",
    "playwright": "^1.58.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@italia/dev-kit-italia": "^1.0.0-alpha.6",
    "bootstrap-italia": "^3.0.0-alpha.5"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "BSD-3-Clause",
  "author": "Daniele Tabellini (Fupete)"
}