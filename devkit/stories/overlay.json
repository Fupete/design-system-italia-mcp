      "html": "<div class=\"container\">\n  <div class=\"row\">\n    <div class=\"col-12 col-md-6\">\n      <p><strong>Overlay ad altezza fissa</strong></p>\n      <figure class=\"overlay-wrapper\">\n        <img\n          src=\"https://picsum.photos/240/160?image=1056\"\n          alt=\"descrizione immagine\"\n          class=\"img-fluid w-100\"\n        />\n        <figcaption class=\"overlay-panel\">\n          <span>Label immagine</span>\n        </figcaption>\n      </figure>\n    </div>\n    <div class=\"col-12 col-md-6\">\n      <p><strong>Overlay a tutta altezza</strong></p>\n      <figure class=\"overlay-wrapper\">\n        <img\n          src=\"https://picsum.photos/240/160?image=1056\"\n          alt=\"descrizione immagine\"\n          class=\"img-fluid w-100\"\n        />\n        <figcaption class=\"overlay-panel overlay-panel-fullheight\">\n          <span>Label immagine</span>\n        </figcaption>\n      </figure>\n    </div>\n    <div class=\"col-12\">\n      <p><strong>Esempio con differenti proporzioni</strong></p>\n      <figure class=\"overlay-wrapper w-100\">\n        <img\n          src=\"https://picsum.photos/800/300?image=1055\"\n          alt=\"descrizione immagine\"\n          class=\"img-fluid w-100\"\n        />\n        <figcaption class=\"overlay-panel\">\n          <span>Label immagine</span>\n        </figcaption>\n      </figure>\n    </div>\n  </div>\n</div>"
