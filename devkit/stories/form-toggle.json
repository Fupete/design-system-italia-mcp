    },
    {
      "name": "stato-disabilitato",
      "html": "<div class=\"mb-3\">\n  <h6 class=\"mb-2\">Disabilitati</h6>\n  <it-toggle name=\"toggle-esempio\" disabled=\"\">\n    <span slot=\"label\">Interruttore disabilitato (spento)</span>\n  </it-toggle>\n</div>\n<div class=\"mb-3\">\n  <it-toggle name=\"toggle-esempio\" checked=\"\" disabled=\"\">\n    <span slot=\"label\">Interruttore disabilitato (acceso)</span>\n  </it-toggle>\n</div>"
    },
    {
