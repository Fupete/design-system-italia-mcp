    },
    {
      "name": "inline",
      "html": "<it-toggle-group name=\"toggle-inline\" inline=\"\">\n  <span slot=\"legend\">Gruppo di toggle</span>\n  <it-toggle value=\"option1\">\n    <span slot=\"label\">Interruttore 1</span>\n  </it-toggle>\n  <it-toggle value=\"option2\" checked=\"\">\n    <span slot=\"label\">Interruttore 2</span>\n  </it-toggle>\n  <it-toggle value=\"option3\">\n    <span slot=\"label\">Interruttore 3</span>\n  </it-toggle>\n</it-toggle-group>"
    },
    {
      "name": "raggruppati-visivamente",
