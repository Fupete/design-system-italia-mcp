# GitHub Personal Access Token
# Scope richiesto: repo (read-only)
# Necessario per: GitHub Issues REST API (fonte #8)
# Senza token: rate limit 60 req/ora per IP; con token: 5000 req/ora
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Porta HTTP del server MCP
PORT=8080

# Token per endpoint di invalidazione cache manuale
# POST /cache/invalidate con header Authorization: Bearer <token>
# Genera con: openssl rand -hex 32
CACHE_INVALIDATION_TOKEN=

# Transport MCP: "http" per server remoto, "stdio" per uso locale con Claude Desktop/Cursor
# Default: http
TRANSPORT=http

# Ambiente (development | production)
NODE_ENV=development
